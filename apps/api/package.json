{
  "name": "@ilinga/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@ilinga/db": "workspace:*",
    "@ilinga/emails": "workspace:*",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ilinga/eslint-config": "workspace:*",
    "@ilinga/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
