###
# Ilinga — local development env
# Copy to .env and adjust. Sourced by apps/api, apps/web, apps/workers, packages/db.
###

# Runtime
NODE_ENV=development
IL_REGION=eu

# Database (CockroachDB with pgvector)
IL_DB_URL=postgresql://root@localhost:26257/ilinga?sslmode=disable

# Object storage (R2 in prod, MinIO locally)
IL_S3_ENDPOINT=http://localhost:9000
IL_S3_REGION=auto
IL_S3_BUCKET=ilinga-eu
IL_S3_ACCESS_KEY=ilinga
IL_S3_SECRET_KEY=ilinga-dev-secret
IL_S3_FORCE_PATH_STYLE=true

# Cookies / origins
IL_COOKIE_DOMAIN=localhost
IL_WEB_ORIGIN=http://localhost:5173
IL_API_ORIGIN=http://localhost:3001

# KMS
IL_KMS_KEK_HEX=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# Auth
IL_SESSION_TTL_HOURS=24
IL_DEVICE_TRUST_DAYS=30
IL_MAGIC_LINK_TTL_MIN=15
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:3001/v1/auth/google/callback

# Email (Mailpit locally; Resend + Postmark in prod)
IL_EMAIL_PRIMARY=smtp
IL_EMAIL_FAILOVER=smtp
IL_EMAIL_SMTP_HOST=localhost
IL_EMAIL_SMTP_PORT=1025
IL_EMAIL_FROM=Ilinga <noreply@ilinga.local>
IL_EMAIL_REPLY_TO=team@ilinga.local

# Dodo Payments
DODO_API_KEY=test_dodo_key
DODO_WEBHOOK_SECRET=test_dodo_webhook_secret
DODO_BASE_URL=https://api.dodopayments.com

# n8n
N8N_INBOUND_URL=http://127.0.0.1:5678
N8N_INBOUND_SECRET=dev-n8n-inbound-secret
N8N_CALLBACK_SECRET=dev-n8n-callback-secret
N8N_API_KEY=

# System AI fallback (set a real key to actually call OpenAI)
IL_SYSTEM_OPENAI_KEY=
IL_SYSTEM_OPENAI_MODEL=gpt-4o

# Queues + SSE pubsub
IL_REDIS_URL=redis://localhost:6379

# Logging / observability
IL_LOG_LEVEL=debug
IL_REQUEST_ID_HEADER=X-Request-Id

# Bot defence
HCAPTCHA_SECRET=

# Worker config
IL_WORKERS_RENDER_CONCURRENCY=2
IL_WORKERS_SCAN_CONCURRENCY=4
IL_WORKERS_EMBED_CONCURRENCY=4

# Maintenance
IL_MAINTENANCE_BANNER=
