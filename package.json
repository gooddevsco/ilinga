{
  "name": "ilinga",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "e2e": "pnpm --filter @ilinga/web exec playwright test",
    "e2e:no-dead-ui": "pnpm --filter @ilinga/web exec playwright test no-dead-ui",
    "a11y": "pnpm --filter @ilinga/web exec playwright test a11y",
    "lighthouse": "pnpm --filter @ilinga/web exec lhci autorun",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:migrate": "pnpm --filter @ilinga/db exec drizzle-kit migrate",
    "db:generate": "pnpm --filter @ilinga/db exec drizzle-kit generate",
    "db:seed": "pnpm --filter @ilinga/db exec tsx src/seed/index.ts",
    "db:reset": "pnpm --filter @ilinga/db exec tsx src/seed/reset.ts",
    "audit:verify": "pnpm --filter @ilinga/api exec tsx src/scripts/verify-audit-chain.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
